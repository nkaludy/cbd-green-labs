<?xml version="1.0"?>
<ruleset name="master-template">
    <description>WordPress Coding Standards for this project's custom code only.</description>

    <!-- Only lint custom code: child theme(s) and custom plugin(s). Vendor themes/plugins,
         WordPress core, and node_modules/vendor are never linted. -->
    <file>./wp-content/themes</file>
    <file>./wp-content/plugins</file>

    <exclude-pattern>*/wp-content/themes/astra/*</exclude-pattern>
    <exclude-pattern>*/wp-content/themes/twentytwentyfour/*</exclude-pattern>
    <exclude-pattern>*/wp-content/plugins/advanced-custom-fields/*</exclude-pattern>
    <exclude-pattern>*/wp-content/plugins/copy-delete-posts/*</exclude-pattern>
    <exclude-pattern>*/wp-content/plugins/custom-post-type-ui/*</exclude-pattern>
    <exclude-pattern>*/wp-content/plugins/litespeed-cache/*</exclude-pattern>
    <exclude-pattern>*/wp-content/plugins/pretty-link/*</exclude-pattern>
    <exclude-pattern>*/wp-content/plugins/seo-by-rank-math/*</exclude-pattern>
    <exclude-pattern>*/wp-content/plugins/shortpixel-image-optimiser/*</exclude-pattern>
    <exclude-pattern>*/wp-content/plugins/updraftplus/*</exclude-pattern>
    <exclude-pattern>*/wp-content/plugins/wpforms-lite/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <rule ref="WordPress">
        <!-- Relax file-naming rule: not all plugin/theme authors follow WP's class-file naming. -->
        <exclude name="WordPress.Files.FileName"/>
    </rule>

    <config name="minimum_supported_wp_version" value="6.5"/>
</ruleset>
